---
import BaseLayout from '../layouts/BaseLayout.astro';

// Logos cargando desde tu carpeta /public/
const partners = [
  { name: "Aspel", src: "/aspel.webp" },
  { name: "Contalink", src: "/contalink.jpeg" },
  { name: "CONTPAQi", src: "/CONTPQI.png" },
  { name: "IMCP", src: "/imcp.png" },
  { name: "Microsoft", src: "/microsoft.webp" },
  { name: "NOMS", src: "/noms.webp" },
  { name: "Oracle", src: "/oracle.jpg" },
  { name: "Python", src: "/Python.webp" },
  { name: "Quickbooks", src: "/quickboks.jpeg" },
  { name: "SAP", src: "/sap.png" },
  { name: "VSC", src: "/vsc.png" }
];
---

<BaseLayout title="Nuestra Firma | NRG Consulting">

  <section class="relative py-32 px-8 overflow-hidden">
    <div class="absolute inset-0 bg-neutral-900">
      <div class="absolute inset-0 opacity-20 bg-[url('https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80')] bg-cover bg-center"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent to-white"></div>
    </div>
    
    <div class="relative max-w-6xl mx-auto z-10 pt-16">
      <span class="text-[10px] font-bold tracking-[0.4em] text-emerald-600 uppercase mb-6 block drop-shadow-sm">Nuestra Firma</span>
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <h1 class="text-4xl md:text-6xl font-serif text-neutral-900 leading-tight">
          La vanguardia tecnológica <span class="italic text-emerald-600">al servicio de su estructura fiscal</span>.
        </h1>
        <div class="space-y-6 text-neutral-700 text-lg font-light border-l-2 border-emerald-500 pl-8 bg-white/40 backdrop-blur-md p-8 rounded-r-2xl shadow-sm">
          <p>
            En NRG Consulting, nuestra práctica trasciende la consultoría tradicional. Fundamentados en el <strong>Principio de Control Total</strong>, integramos una visión multidisciplinaria que combina la precisión contable, la estrategia fiscal y el blindaje legal, todo potenciado por soluciones tecnológicas a medida.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 px-8 bg-white">
    <div class="max-w-6xl mx-auto">
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-32 border-y border-neutral-100 py-16">
        {[ {n: "+100", t: "Proyectos Ejecutados"}, {n: "100%", t: "Control de Gestión"}, {n: "+5", t: "Años de Experiencia"}, {n: "24/7", t: "Soporte Técnico"} ].map(item => (
          <div class="text-center group cursor-default">
            <div class="text-4xl font-bold text-neutral-950 group-hover:text-emerald-600 transition-colors duration-300">{item.n}</div>
            <div class="text-[9px] uppercase tracking-widest text-neutral-400 mt-3 group-hover:text-emerald-600 transition-colors duration-300">{item.t}</div>
          </div>
        ))}
      </div>

      <div class="mb-32">
        <h2 class="text-[10px] font-bold tracking-[0.4em] uppercase text-neutral-400 mb-16 border-b border-neutral-100 pb-4">Dirección Estratégica</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {[
            { name: "Juan Carlos Guzmán Herrera", area: "Socio Consultor", desc: "Especialista en auditoría financiera y liderazgo en procesos de consultoría estratégica de negocios.", img: "/carlos.jpeg" },
            { name: "Antonio Rubio Basaldua", area: "Socio Consultor", desc: "Experto en reingeniería de procesos internos, control de gestión y optimización de capital operativo.", img: "/antonio.jpeg" },
            { name: "Miguel Ángel Nava Velázquez", area: "Socio Consultor", desc: "Estratega en operaciones de comercio exterior, logística global, automatización y cumplimiento corporativo.", img: "/angel.png" }
          ].map((socio) => (
            <div class="relative bg-white p-8 border border-neutral-100 shadow-lg shadow-neutral-100/75 hover:-translate-y-3 hover:shadow-2xl hover:border-emerald-100 transition-all duration-500 ease-out group overflow-hidden flex flex-col justify-between">
              <div>
                <div class="w-24 h-24 mb-8 bg-neutral-100 overflow-hidden rounded-full shadow-inner border border-neutral-200 flex items-center justify-center group-hover:border-emerald-500 transition-all duration-500">
                  <img 
                    src={socio.img} 
                    alt={socio.name}
                    class="w-full h-full object-cover grayscale group-hover:grayscale-0 scale-100 group-hover:scale-110 transition-all duration-700"
                    onerror="this.src='/logo.pgn.jpeg'; this.style.opacity='0.3';" 
                  />
                </div>
                <span class="text-[9px] font-bold tracking-[0.2em] text-emerald-600 uppercase block mb-3">{socio.area}</span>
                <h3 class="text-lg font-bold text-neutral-950 mb-4">{socio.name}</h3>
                <p class="text-sm text-neutral-500 leading-relaxed font-light mb-6">{socio.desc}</p>
              </div>
              <div class="absolute bottom-0 left-0 w-0 h-1 bg-emerald-600 group-hover:w-full transition-all duration-700 ease-in-out"></div>
            </div>
          ))}
        </div>

        {/* Tarjeta de Aliado Estratégico limpia y original (sin contenedor de imagen) */}
        <div class="mt-8 relative bg-white border border-neutral-200 p-8 flex items-center justify-between shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-emerald-600 transition-all duration-500 group overflow-hidden">
          <div class="relative z-10">
            <span class="text-[9px] font-bold tracking-[0.2em] text-neutral-400 group-hover:text-emerald-600 transition-colors uppercase block mb-1">Aliado Estratégico</span>
            <h3 class="text-md font-bold text-neutral-950">Carlos Emiliano Mora Montes</h3>
            <p class="text-xs text-neutral-500 font-light mt-1">Servicio Legal Asociado | Consultoría jurídica integral y defensa corporativa.</p>
          </div>
          <div class="absolute top-0 right-0 w-32 h-full bg-gradient-to-l from-emerald-50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-neutral-50 px-8 text-center">
    <h2 class="text-2xl md:text-4xl font-serif text-neutral-900 italic max-w-3xl mx-auto">
      "El Principio de Control Total no es solo una metodología, es nuestro compromiso con la integridad de su patrimonio."
    </h2>
  </section>

  <section class="py-16 bg-white border-y border-neutral-100">
    <div class="max-w-6xl mx-auto px-8 text-center mb-10">
      <h3 class="text-[10px] font-bold tracking-[0.4em] uppercase text-neutral-400">Tecnología y Alianzas Estratégicas</h3>
    </div>
    
    <div class="relative max-w-6xl mx-auto overflow-hidden">
      <div class="flex animate-marquee gap-24 items-center whitespace-nowrap">
        {[...partners, ...partners].map((p) => (
          <div class="flex-shrink-0 flex items-center justify-center w-40 h-20 transition-all duration-500 hover:scale-110 cursor-default opacity-100">
            <img 
              src={p.src} 
              alt={p.name} 
              class="max-h-16 w-auto object-contain" 
              style="filter: none !important;"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-neutral-950 py-24 px-8 relative overflow-hidden">
    <div class="absolute top-1/4 right-0 w-1/2 h-1/2 bg-emerald-900/20 blur-[150px] rounded-full pointer-events-none"></div>
    <div class="max-w-6xl mx-auto relative z-10">
      <h2 class="text-sm font-bold tracking-[0.2em] uppercase text-emerald-500 mb-16 border-b border-neutral-800 pb-4">Infraestructura Operativa</h2>
      <div class="grid md:grid-cols-3 gap-x-12 gap-y-16">
        {[
          { t: "Finanzas y Cumplimiento", d: "Contabilidad, impuestos, nóminas e IMSS con planeación fiscal ética." },
          { t: "Estrategia de Negocios", d: "Proyectos de inversión, planes de negocio y control interno." },
          { t: "Automatización y Tech", d: "Desarrollo a la medida, automatización de flujos financieros y plataformas web." },
          { t: "Consultoría Legal", d: "Blindaje legal corporativo y defensa estratégica en alianza." },
          { t: "Comercio Exterior", d: "Logística internacional y regímenes aduaneros especializados." },
          { t: "Control de Gestión", d: "Mitigación de riesgos y arquitectura de sistemas para toma de decisiones." }
        ].map(dept => (
          <div class="group border-l-2 border-neutral-800 pl-8 hover:border-emerald-500 transition-all duration-300">
            <h4 class="text-sm font-bold mb-4 text-white group-hover:text-emerald-400 transition-colors">{dept.t}</h4>
            <p class="text-xs text-neutral-400 font-light group-hover:text-neutral-300 transition-colors">{dept.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 px-8 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-3 gap-12 text-center">
        {[ 
          {t: "Automatización", d: "Procesos digitales"}, 
          {t: "Control Total", d: "Blindaje institucional"}, 
          {t: "Estrategia", d: "Visión corporativa"} 
        ].map(m => (
          <div class="group cursor-default hover:-translate-y-2 transition-transform duration-500">
             <div class="w-16 h-16 border border-neutral-200 group-hover:border-emerald-600 group-hover:bg-emerald-50 mx-auto mb-6 flex items-center justify-center transition-all duration-500 rotate-45 group-hover:rotate-0">
                <div class="w-2 h-2 bg-emerald-600 rounded-full"></div>
             </div>
             <h4 class="font-bold text-neutral-950">{m.t}</h4>
             <p class="text-[10px] text-neutral-400 uppercase tracking-widest mt-2">{m.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  
</BaseLayout>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    animation: marquee 30s linear infinite;
  }
</style>