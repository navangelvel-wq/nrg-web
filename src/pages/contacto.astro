---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contacto | NRG Consulting">

  <section class="bg-neutral-950 py-16 px-8 text-center relative overflow-hidden">
    <div class="absolute top-0 right-0 w-80 h-80 bg-emerald-900/10 blur-[100px] rounded-full pointer-events-none"></div>
    <div class="relative max-w-4xl mx-auto pt-8">
      <span class="text-[10px] font-bold tracking-[0.4em] text-emerald-500 uppercase mb-3 block">Contacto</span>
      <h1 class="text-3xl md:text-4xl font-serif text-white">Estamos aquí para atenderle</h1>
      <p class="text-neutral-400 font-light text-sm mt-3 max-w-xl mx-auto leading-relaxed">
        Póngase en contacto con nuestro equipo de expertos para resolver cualquier requerimiento corporativo.
      </p>
    </div>
  </section>

  <section class="py-16 px-8 bg-white">
    <div class="max-w-6xl mx-auto grid md:grid-cols-12 gap-12 lg:gap-16 items-start">
      
      <div class="md:col-span-7 space-y-6">
        <div>
          <h2 class="text-xl font-bold text-neutral-950 mb-1">Envíenos un mensaje</h2>
          <p class="text-xs text-neutral-400 font-light">Complete el formulario y nos pondremos en contacto con usted a la brevedad.</p>
        </div>

        <form id="formulario-contacto" class="space-y-5">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-[10px] font-bold text-neutral-400 uppercase block mb-1">Nombre *</label>
              <input type="text" name="nombre" required class="w-full bg-neutral-50 border border-neutral-200 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/10 rounded px-4 py-2.5 text-xs text-neutral-900 placeholder:text-neutral-300 outline-none transition-all" placeholder="Nombre" />
            </div>
            <div>
              <label class="text-[10px] font-bold text-neutral-400 uppercase block mb-1">Apellidos *</label>
              <input type="text" name="apellidos" required class="w-full bg-neutral-50 border border-neutral-200 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/10 rounded px-4 py-2.5 text-xs text-neutral-900 placeholder:text-neutral-300 outline-none transition-all" placeholder="Apellidos" />
            </div>
          </div>

          <div>
            <label class="text-[10px] font-bold text-neutral-400 uppercase block mb-1">Empresa</label>
            <input type="text" name="empresa" class="w-full bg-neutral-50 border border-neutral-200 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/10 rounded px-4 py-2.5 text-xs text-neutral-900 placeholder:text-neutral-300 outline-none transition-all" placeholder="Razón Social o Nombre Comercial" />
          </div>

          <div>
            <label class="text-[10px] font-bold text-neutral-400 uppercase block mb-1">Servicio de Interés *</label>
            <select name="servicio" required class="w-full bg-neutral-50 border border-neutral-200 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/10 rounded px-4 py-2.5 text-xs text-neutral-500 outline-none transition-all">
              <option value="" disabled selected>-- Seleccione la opción --</option>
              <option value="Tax & Financial Services">Tax & Financial Services</option>
              <option value="Business Consulting">Business Consulting</option>
              <option value="Riesgos y Control Interno">Riesgos y Control Interno</option>
              <option value="Comercio Internacional">Comercio Internacional</option>
              <option value="Digital Solutions">Digital Solutions</option>
              <option value="Marketing y Crecimiento">Marketing y Crecimiento</option>
            </select>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-[10px] font-bold text-neutral-400 uppercase block mb-1">Correo electrónico *</label>
              <input type="email" name="email" required class="w-full bg-neutral-50 border border-neutral-200 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/10 rounded px-4 py-2.5 text-xs text-neutral-900 placeholder:text-neutral-300 outline-none transition-all" placeholder="correo@empresa.com" />
            </div>
            <div>
              <label class="text-[10px] font-bold text-neutral-400 uppercase block mb-1">Teléfono</label>
              <input type="tel" name="telefono" class="w-full bg-neutral-50 border border-neutral-200 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/10 rounded px-4 py-2.5 text-xs text-neutral-900 placeholder:text-neutral-300 outline-none transition-all" placeholder="10 dígitos" />
            </div>
          </div>

          <div>
            <label class="text-[10px] font-bold text-neutral-400 uppercase block mb-1">¿En qué podemos ayudarle?</label>
            <textarea name="mensaje" rows="4" class="w-full bg-neutral-50 border border-neutral-200 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/10 rounded px-4 py-2.5 text-xs text-neutral-900 placeholder:text-neutral-300 outline-none transition-all resize-none" placeholder="Escriba su mensaje aquí..."></textarea>
          </div>

          <div class="space-y-3 pt-2">
            <span class="text-[10px] font-bold text-neutral-400 uppercase block">Aviso de Privacidad *</span>
            <label class="flex items-start gap-2 cursor-pointer select-none">
              <input type="checkbox" required class="mt-1 rounded border-neutral-300 text-emerald-500 focus:ring-emerald-500/20" />
              <span class="text-[11px] text-neutral-500 leading-snug">
                Aceptar. Al enviar este formulario usted manifiesta estar de acuerdo con nuestro <a href="/privacidad" class="text-emerald-600 hover:underline font-medium">Aviso de Privacidad</a>.
              </span>
            </label>
          </div>

          <div id="notificacion-estado" class="hidden text-xs font-medium p-3.5 rounded border"></div>

          <button type="submit" id="boton-enviar" class="bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-bold uppercase tracking-wider px-8 py-3 rounded transition-all shadow-sm cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed">
            Enviar
          </button>
        </form>
      </div>

      <div class="md:col-span-5 space-y-8 lg:pl-6">
        <div>
          <span class="text-[9px] font-bold tracking-widest text-emerald-600 uppercase mb-1 block">Información de contacto</span>
          <h2 class="text-xl font-bold text-neutral-950 mb-6">Estamos aquí para usted</h2>
          <p class="text-xs text-neutral-400 font-light leading-relaxed">
            Nuestro equipo de expertos está listo para atender sus necesidades operativas, fiscales y de negocio desde nuestras instalaciones.
          </p>
        </div>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-emerald-50 flex items-center justify-center text-emerald-600 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <h4 class="text-xs font-bold text-neutral-900">Correo Electrónico</h4>
              <a href="mailto:nrgconsultores@outlook.com" class="text-xs text-neutral-500 hover:text-emerald-600 transition-colors">nrgconsultores@outlook.com</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-emerald-50 flex items-center justify-center text-emerald-600 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div>
              <h4 class="text-xs font-bold text-neutral-900">Teléfono Principal</h4>
              <a href="tel:+524424607975" class="text-xs text-neutral-500 hover:text-emerald-600 transition-colors">(442) 460 7975</a>
            </div>
          </div>

          <a 
            href="https://wa.me/524424607975" 
            target="_blank" 
            rel="noopener noreferrer" 
            class="flex items-center justify-between gap-4 p-3.5 rounded-lg border border-emerald-100 bg-emerald-50/40 hover:bg-emerald-50 hover:border-emerald-300 transition-all duration-300 group cursor-pointer no-underline"
          >
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-emerald-500 text-white flex items-center justify-center shrink-0 shadow-sm group-hover:scale-105 transition-transform duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.458 5.704 1.459h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                </svg>
              </div>
              <div>
                <h4 class="text-xs font-bold text-neutral-900">WhatsApp</h4>
                <p class="text-xs text-neutral-500 group-hover:text-neutral-700 transition-colors">(442) 460 7975</p>
              </div>
            </div>
            <span class="text-[10px] font-bold text-emerald-600 bg-emerald-100/50 group-hover:bg-emerald-600 group-hover:text-white px-2.5 py-1 rounded-full uppercase tracking-wider transition-all duration-300">
              Escribir
            </span>
          </a>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-emerald-50 flex items-center justify-center text-emerald-600 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h4 class="text-xs font-bold text-neutral-900">Horario de Atención</h4>
              <p class="text-xs text-neutral-500">Lunes a Viernes: 9:00 AM – 6:00 PM</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <section class="py-16 px-8 bg-neutral-50 border-t border-neutral-100">
    <div class="max-w-6xl mx-auto">
      
      <div class="flex justify-center space-x-2 md:space-x-4 mb-10">
        <button class="bg-emerald-600 text-white font-medium text-[11px] uppercase tracking-wider px-6 py-2.5 rounded shadow-sm transition-all focus:outline-none">
          Querétaro
        </button>
        <button class="bg-white border border-neutral-200 text-neutral-400 font-medium text-[11px] uppercase tracking-wider px-6 py-2.5 rounded cursor-not-allowed opacity-70">
          CDMX (Próximamente)
        </button>
      </div>

      <div class="bg-white border border-neutral-200/60 rounded-xl overflow-hidden shadow-sm grid md:grid-cols-12">
        
        <div class="p-8 md:p-10 md:col-span-5 flex flex-col justify-center space-y-6">
          <div>
            <span class="text-[9px] font-bold tracking-widest text-emerald-600 uppercase mb-1 block">Corporativo Principal</span>
            <h3 class="text-xl font-bold text-neutral-950 mb-4">NRG Consulting</h3>
            
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <div class="text-xs text-neutral-600 leading-relaxed font-light">
                  <p class="font-semibold text-neutral-800 mb-0.5">IZA Business Centers (Torre 57)</p>
                  <p>Piso 14, Prol. Bernardo Quintana 300 / Acceso a La Central,</p>
                  <p>Centro Sur, 76090 Santiago de Querétaro, Qro.</p>
                </div>
              </div>

              <div class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                <a href="tel:+524424607975" class="text-xs text-neutral-600 hover:text-emerald-600 transition-colors font-light">(442) 460 7975</a>
              </div>

              <div class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <p class="text-xs text-neutral-600 font-light">Lunes a Viernes: 9:00 AM – 6:00 PM</p>
              </div>
            </div>
          </div>
          
          <div class="pt-4 border-t border-neutral-100">
            <p class="text-[11px] text-neutral-400 font-light leading-relaxed">
              * Para calcular su distancia y ruta en tiempo real, haga clic en el botón <strong class="text-neutral-600 font-medium">"Cómo llegar"</strong> directamente en la vista interactiva.
            </p>
          </div>
        </div>

        <div class="md:col-span-7 h-[350px] md:h-full min-h-[380px] w-full relative bg-neutral-100">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3734.908064972288!2d-100.36547292420894!3d20.579799903027202!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85d35bf90fa09c9d%3A0x42c141f55d713ce8!2sIZA%20Business%20Centers%20Torre%2057!5e0!3m2!1ses-419!2smx!4v1700000000000!5m2!1ses-419!2smx"
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            class="absolute inset-0 w-full h-full"
          ></iframe>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<script>
  const formulario = document.getElementById('formulario-contacto') as HTMLFormElement;
  const notificacion = document.getElementById('notificacion-estado') as HTMLDivElement;
  const boton = document.getElementById('boton-enviar') as HTMLButtonElement;

  if (formulario) {
    formulario.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      boton.disabled = true;
      boton.textContent = 'Enviando...';
      notificacion.className = 'text-xs font-medium p-3.5 rounded border hidden';

      const datosFormulario = new FormData(formulario);

      try {
        // CORRECCIÓN: Apunta explícitamente a /api/contacto.js
        const respuesta = await fetch('/api/contacto.js', {
          method: 'POST',
          body: datosFormulario
        });

        const resultado = await respuesta.json();

        if (respuesta.ok) {
          notificacion.classList.remove('hidden');
          notificacion.classList.add('bg-emerald-50', 'text-emerald-800', 'border-emerald-200');
          notificacion.textContent = '✓ Mensaje enviado correctamente. Le contactaremos muy pronto.';
          formulario.reset();
        } else {
          throw new Error(resultado.message || 'Ocurrió un error inesperado.');
        }
      } catch (error: any) {
        notificacion.classList.remove('hidden');
        notificacion.classList.add('bg-rose-50', 'text-rose-800', 'border-rose-200');
        notificacion.textContent = `✗ Error: ${error.message || 'No se pudo conectar con el servidor.'}`;
      } finally {
        boton.disabled = false;
        boton.textContent = 'Enviar';
      }
    });
  }
</script>