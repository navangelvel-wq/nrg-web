---
// src/components/ChatbotEjecutivo.astro
---

<section class="bg-neutral-950 py-24 px-8 border-t border-neutral-900 relative overflow-hidden">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-emerald-500/5 blur-[120px] rounded-full pointer-events-none"></div>

  <div class="max-w-5xl mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      
      <div class="lg:col-span-5 space-y-6">
        <span class="text-xs uppercase tracking-widest text-emerald-400 font-semibold bg-emerald-950/50 px-3 py-1.5 rounded-full border border-emerald-900/40">
          Evaluación Digital
        </span>
        <h2 class="text-3xl lg:text-4xl font-bold tracking-tight text-white leading-tight">
          Diagnóstico de <br><span class="text-transparent bg-clip-text bg-gradient-to-r from-neutral-100 to-neutral-400">Estrategia Empresarial</span>
        </h2>
        <p class="text-neutral-400 text-[14px] leading-relaxed font-light">
          Utilice nuestro asistente inteligente para perfilar los retos actuales de su organización. En menos de 2 minutos obtendrá una pre-calificación para una sesión estratégica con nuestros socios directores.
        </p>
        <div class="flex items-center space-x-4 text-xs text-neutral-500 pt-2">
          <div class="flex items-center gap-1.5">
            <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
            Disponible 24/7
          </div>
          <span>•</span>
          <div>Confidencialidad Encriptada</div>
        </div>
      </div>

      <div class="lg:col-span-7">
        <div class="bg-neutral-900/60 backdrop-blur-md border border-neutral-800/80 rounded-2xl p-2 shadow-2xl shadow-black/50 w-full h-[550px] relative overflow-hidden">
          
          <div class="flex items-center justify-between px-4 py-3 border-b border-neutral-800/60 bg-neutral-900/40 rounded-t-xl">
            <div class="flex items-center space-x-3">
              <div class="w-6 h-6 rounded-full bg-neutral-950 flex items-center justify-center border border-neutral-800">
                <span class="text-emerald-400 font-bold text-[10px]">N.</span>
              </div>
              <span class="text-xs font-medium text-neutral-300 tracking-wide">NRG Strategy Assistant</span>
            </div>
            <div class="flex space-x-1.5">
              <div class="w-2 h-2 rounded-full bg-neutral-800"></div>
              <div class="w-2 h-2 rounded-full bg-neutral-800"></div>
            </div>
          </div>

          <div id="contenedor-bot-embebido" class="w-full h-[calc(100%-40px)] rounded-b-xl overflow-hidden bg-neutral-950/40">
            <div id="bot-loader" class="w-full h-full flex flex-col items-center justify-center space-y-3 text-neutral-600">
              <svg class="animate-spin w-5 h-5 text-emerald-500" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              <span class="text-xs tracking-wider">Iniciando interfaz...</span>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline type="module">
  import Typebot from 'https://cdn.jsdelivr.net/npm/@typebot.io/js@0.3/dist/web.js'

  // Inicializamos el bot directamente inyectado en la caja
  Typebot.initStandard({
    targetElement: document.getElementById('contenedor-bot-embebido'),
    typebot: "nrg-consulting-calificador", // Tu ID real de Typebot
  });

  // Ocultamos el loader una vez inicializado
  setTimeout(() => {
    const loader = document.getElementById('bot-loader');
    if (loader) loader.style.display = 'none';
  }, 800);
</script>