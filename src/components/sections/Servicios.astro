---
// src/components/sections/Servicios.astro

// Catálogo de Servicios con identificadores de redirección únicos (id)
const areasServicio = [
  {
    id: "fiscal-financiera",
    title: "Consultoría Fiscal y Financiera",
    description: "Ayudamos a las organizaciones a optimizar su cumplimiento fiscal y fortalecer su posición financiera mediante estrategias alineadas con sus objetivos empresariales.",
    items: ["Cumplimiento fiscal", "Planeación financiera", "Estados financieros", "Presupuestos y proyecciones", "Análisis financiero", "Gestión administrativa"]
  },
  {
    id: "empresarial",
    title: "Consultoría Empresarial",
    description: "Acompañamos a las empresas en la toma de decisiones estratégicas que impulsan su crecimiento y competitividad.",
    items: ["Planes de negocio", "Estudios de viabilidad", "Modelos de negocio", "Planeación estratégica", "Desarrollo organizacional", "Optimización operativa"]
  },
  {
    id: "control-interno",
    title: "Riesgos, Procesos y Control Interno",
    description: "Fortalecemos la estructura operativa de las organizaciones mediante controles efectivos y procesos eficientes.",
    items: ["Diseño de controles internos", "Gestión de riesgos", "Manuales y procedimientos", "Gobierno corporativo", "Mapeo de procesos", "Cumplimiento organizacional"]
  },
  {
    id: "comercio-internacional",
    title: "Comercio Internacional",
    description: "Apoyamos a las empresas que participan en mercados globales mediante soluciones orientadas al comercio exterior y la expansión internacional.",
    items: ["Importación y exportación", "Estrategia internacional", "Logística global", "Cumplimiento comercial", "Inteligencia de mercados", "Desarrollo de proveedores"]
  },
  {
    id: "transformacion-digital",
    title: "Transformación Digital",
    description: "Integramos tecnología para mejorar la productividad, automatizar procesos y fortalecer la toma de decisiones.",
    items: ["Desarrollo web corporativo", "Dashboards ejecutivos", "Bases de datos", "Automatización de procesos", "Inteligencia artificial aplicada", "Transformación digital"]
  },
  {
    id: "marketing-crecimiento",
    title: "Marketing y Crecimiento Comercial",
    description: "Diseñamos estrategias orientadas a incrementar la visibilidad, generación de prospectos y posicionamiento empresarial.",
    items: ["Marketing digital", "Gestión de campañas", "Posicionamiento web", "Branding corporativo", "Estrategias comerciales"]
  }
];
---

<section id="servicios" class="py-24 bg-slate-100/60 border-t border-slate-200">
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Encabezado -->
    <div class="text-center max-w-3xl mx-auto mb-20">
      <span class="text-xs font-bold tracking-widest text-slate-500 uppercase block mb-3">Soluciones Avanzadas</span>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 tracking-tight mb-4">
        Áreas de Servicio
      </h2>
      <p class="text-lg text-slate-600 leading-relaxed">
        Estructuramos soluciones especializadas con visión global para atender las demandas más exigentes del entorno corporativo.
      </p>
    </div>

    <!-- Grid de Tarjetas Ejecutivas con ID de Redirección (scroll-mt añade margen superior para que el menú no tape la tarjeta) -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {areasServicio.map((area) => (
        <div id={area.id} class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200/60 flex flex-col justify-between transform hover:-translate-y-1 transition-all duration-300 scroll-mt-28">
          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-3 tracking-tight border-b border-slate-100 pb-3">
              {area.title}
            </h3>
            <p class="text-slate-600 text-sm leading-relaxed mb-6">
              {area.description}
            </p>
          </div>

          <ul class="space-y-2 border-t border-slate-50 pt-4">
            {area.items.map((item) => (
              <li class="flex items-center text-xs font-medium text-slate-700">
                <span class="w-1.5 h-1.5 bg-slate-900 rounded-full mr-2.5 opacity-60"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

  </div>
</section>